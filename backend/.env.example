MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-key-change-in-production
PORT=5000
CORS_ORIGIN=http://localhost:3000  # only needed for direct API testing (curl/Postman); browser flow uses rewrites proxy
COOKIE_SECURE=false                # true in production (HTTPS only)
COOKIE_SAMESITE=lax                # lax (or strict) — same-origin via proxy, no need for None